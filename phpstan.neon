parameters:
    level: 5
    paths:
        - .
    excludePaths:
        - vendor
    bootstrapFiles:
        - vendor/php-stubs/wordpress-stubs/wordpress-stubs.php
    # Ignore errors from WordPress globals that PHPStan can't see at runtime
    ignoreErrors:
        - '#^Function apply_filters#'
        - '#^Function do_action#'
